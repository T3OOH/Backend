generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Panel {
  id          String           @id @default(uuid())
  name        String
  description String?
  address     String?
  city        String?
  state       String?
  images      String[]
  categoryId  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  impacts     String
  lat         Float
  lng         Float
  px          String
  size        String
  price       Float?
  status      PanelStatus      @default(AVAILABLE)
  analytics   AnalyticsEvent[]
  category    Category?        @relation(fields: [categoryId], references: [id])

  @@index([city, state])
  @@map("panels")
}

model Category {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  panels      Panel[]

  @@map("categories")
}

model Contact {
  id        String        @id @default(uuid())
  name      String
  company   String?
  phone     String
  email     String
  message   String
  ip        String?
  userAgent String?
  origin    String?
  status    ContactStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("contacts")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  group     String
  updatedAt DateTime @updatedAt

  @@index([group])
  @@map("system_settings")
}

model AnalyticsEvent {
  id          String   @id @default(uuid())
  eventType   String
  path        String?
  panelId     String?
  ip          String?
  os          String?
  browser     String?
  deviceModel String?
  country     String?
  city        String?
  referer     String?
  createdAt   DateTime @default(now())
  panel       Panel?   @relation(fields: [panelId], references: [id])

  @@index([eventType, createdAt])
  @@map("analytics_events")
}

enum Role {
  ADMIN
  MANAGER
  USER
}

enum PanelStatus {
  AVAILABLE
  MAINTENANCE
  RESERVED
  OCCUPIED
}

enum ContactStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}
